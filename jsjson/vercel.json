  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "rewrites": [
    { "source": "/auth/google", "destination": "/api/server" },
    { "source": "/api/me", "destination": "/api/server" },
    { "source": "/api/health", "destination": "/api/server" },
    { "source": "/profile", "destination": "/api/server" },
    { "source": "/logout", "destination": "/api/server" }
  ]
}